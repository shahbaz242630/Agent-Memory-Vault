/// Walk `data_dir/*.lance/data/*.lance` and return every fragment file.
/// Mirrors the helper in vector_store.rs's corruption test.
fn find_all_fragments(data_dir: &std::path::Path) -> Vec<std::path::PathBuf> {
    fn walk(dir: &std::path::Path, found: &mut Vec<std::path::PathBuf>) {
        let entries = match std::fs::read_dir(dir) {
            Ok(e) => e,
            Err(_) => return,
        };
        for entry in entries.flatten() {
            let path = entry.path();
            if path.is_dir() {
                walk(&path, found);
            } else if path.extension().and_then(|s| s.to_str()) == Some("lance")
                && path
                    .parent()
                    .and_then(|p| p.file_name())
                    .map(|n| n == "data")
                    .unwrap_or(false)
            {
                found.push(path);
            }
        }
    }
    let mut found = Vec::new();
    walk(data_dir, &mut found);
    found
}

