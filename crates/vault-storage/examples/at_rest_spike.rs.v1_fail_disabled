/// Stage A: identity wrapper. Returns the original ObjectStore unmodified.
/// Proves the `WrappingObjectStore` trait wiring compiles and Lance
/// threads it through both write and read paths.
#[derive(Debug)]
struct IdentityWrapper;

impl WrappingObjectStore for IdentityWrapper {
    fn wrap(&self, original: Arc<dyn ObjectStore>) -> Arc<dyn ObjectStore> {
        original
    }
}

async fn run_stage_a() {
    eprintln!("===== At-rest-extension spike: Stage A =====");
    eprintln!();

    let tmp = tempfile::TempDir::new().expect("tempdir");
    let uri = tmp.path().to_str().expect("temp path utf-8");
    eprintln!("dataset URI: {uri}");

    let batch = make_test_batch(100, 384);
    let schema = batch.schema();
    let reader = RecordBatchIterator::new(vec![Ok(batch)], schema.clone());

    let wrapper: Arc<dyn WrappingObjectStore> = Arc::new(IdentityWrapper);

    let write_params = WriteParams {
        store_params: Some(ObjectStoreParams {
            object_store_wrapper: Some(wrapper.clone()),
            ..Default::default()
        }),
        ..Default::default()
    };

    eprintln!("step 1 — writing 100 rows × 384-dim through identity wrapper...");
    let _ds = Dataset::write(reader, uri, Some(write_params))
        .await
        .expect("dataset write");
    eprintln!("        write OK");

    let read_params = ReadParams {
        store_options: Some(ObjectStoreParams {
            object_store_wrapper: Some(wrapper),
            ..Default::default()
        }),
        ..Default::default()
    };

    eprintln!("step 2 — reading back through identity wrapper...");
    let ds = DatasetBuilder::from_uri(uri)
        .with_read_params(read_params)
        .load()
        .await
        .expect("dataset load");

    let count = ds.count_rows(None).await.expect("count_rows");
    eprintln!("        count: {count}");
    assert_eq!(count, 100, "round-trip row count mismatch");

    eprintln!();
    eprintln!("Stage A: PASS — lance::Dataset + WrappingObjectStore compile + round-trip OK");
}

// ============================================================
//   Stage B — sealing primitives + adversarial assertions
// ============================================================

fn run_stage_b() {
    eprintln!();
    eprintln!("===== At-rest-extension spike: Stage B (sealing primitives) =====");

    // Fixed test inputs for deterministic spike output.
    let master_key: [u8; 32] = *b"this is a 32-byte test mkey-vlt!";
    let at_rest_key = derive_at_rest_key(&master_key);
    eprintln!("derived at_rest_key (K3 = blake3::derive_key)");

    let file_path = "memories.lance/data/abc12345.lance";
    let aad = compute_aad(file_path);
    eprintln!("computed AAD for file_path: {file_path}");

    // Synthetic Parquet-shaped plaintext: 5KB starting + ending with `PAR1`
    // magic, representative of what a small Parquet fragment looks like on
    // disk. The middle is filled with 0xCD so any decryption-without-key
    // would visibly fail the entropy check too.
    let mut plaintext: Vec<u8> = Vec::with_capacity(5120);
    plaintext.extend_from_slice(b"PAR1");
    plaintext.extend(std::iter::repeat(0xCDu8).take(5112));
    plaintext.extend_from_slice(b"PAR1");
    eprintln!(
        "plaintext: {} bytes (begins+ends with PAR1 magic)",
        plaintext.len()
    );

    // Seal.
    let sealed = seal_file_bytes(&plaintext, &at_rest_key, &aad);
    eprintln!(
        "sealed: {} bytes (overhead = {} bytes)",
        sealed.len(),
        sealed.len() - plaintext.len()
    );

    // Round-trip identity.
    let unsealed = unseal_file_bytes(&sealed, &at_rest_key, &aad).expect("unseal round-trip");
    assert_eq!(unsealed, plaintext, "round-trip identity violated");
    eprintln!("✓ round-trip identity OK");

    // Adversarial (a) — bit-flip in ciphertext body fails closed.
    let mut tampered = sealed.clone();
    let flip_offset = TOTAL_FRAMING_LEN + 100; // well into ciphertext body
    tampered[flip_offset] ^= 0x01;
    assert!(
        unseal_file_bytes(&tampered, &at_rest_key, &aad).is_err(),
        "(a) bit-flip MUST fail closed (AEAD authenticity check)"
    );
    eprintln!("✓ (a) bit-flip in ciphertext body fails closed");

    // Adversarial (b) — wrong key fails closed.
    let wrong_master: [u8; 32] = *b"WRONG MASTER KEY for the spk-vlt";
    let wrong_at_rest_key = derive_at_rest_key(&wrong_master);
    assert!(
        unseal_file_bytes(&sealed, &wrong_at_rest_key, &aad).is_err(),
        "(b) wrong-key decryption MUST fail closed"
    );
    eprintln!("✓ (b) wrong-key decryption fails closed");

    // Adversarial (b') — wrong AAD (different file_path) fails closed.
    // Confirms the file_path binding actually fires.
    let wrong_aad = compute_aad("memories.lance/data/different.lance");
    assert!(
        unseal_file_bytes(&sealed, &at_rest_key, &wrong_aad).is_err(),
        "wrong-AAD decryption MUST fail closed (AEAD AAD-binding check)"
    );
    eprintln!("✓ (b') wrong-AAD (different file_path) decryption fails closed");

    // Adversarial (c.1) — no PAR1 magic anywhere in sealed envelope.
    assert!(
        !sealed.windows(4).any(|w| w == b"PAR1"),
        "(c.1) sealed envelope MUST NOT contain Parquet magic"
    );
    eprintln!("✓ (c.1) no PAR1 magic anywhere in sealed envelope");

    // Adversarial (c.2) — entropy of the ciphertext body ≥ 7.9 bits/byte.
    // Skip the framing prefix + header (which contain deterministic /
    // nonce bytes that aren't representative of bulk-payload entropy).
    let body_entropy = shannon_entropy(&sealed[TOTAL_FRAMING_LEN..]);
    eprintln!(
        "ciphertext body entropy: {:.4} bits/byte (require ≥ 7.9)",
        body_entropy
    );
    assert!(
        body_entropy >= 7.9,
        "(c.2) ciphertext body entropy must approach 8.0 bits/byte; got {body_entropy:.4}"
    );
    eprintln!("✓ (c.2) ciphertext body entropy ≥ 7.9 bits/byte");

    eprintln!();
    eprintln!("Stage B: PASS — sealing primitives work; all adversarial assertions hold");
}

