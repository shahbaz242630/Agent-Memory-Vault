/// Stage C wrapper: returns a `SealedObjectStore` decorating the
/// inner store, with sealing keyed by the at-rest key.
struct SealingWrapper {
    key: [u8; 32],
}

impl std::fmt::Debug for SealingWrapper {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        f.debug_struct("SealingWrapper").finish_non_exhaustive()
    }
}

impl WrappingObjectStore for SealingWrapper {
    fn wrap(&self, original: Arc<dyn ObjectStore>) -> Arc<dyn ObjectStore> {
        // Spike trace — kept long-term to document the
        // LocalObjectReader-bypass finding: this fires during BOTH
        // write and read flows, but read flows then bypass our
        // wrapper entirely (no get_opts/head/list traces fire).
        eprintln!("  [trace] SealingWrapper::wrap called (inner={original})");
        Arc::new(SealedObjectStore {
            inner: original,
            key: self.key,
        })
    }
}

/// Sealed wrapper over an inner `ObjectStore`. Intercepts `put_opts`
/// to seal payloads + `get_opts` to unseal results. Other methods
/// delegate to inner. AAD per-call is computed from the location
/// path (Finding 2 candidate (c)).
struct SealedObjectStore {
    inner: Arc<dyn ObjectStore>,
    key: [u8; 32],
}

impl std::fmt::Debug for SealedObjectStore {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        f.debug_struct("SealedObjectStore").finish_non_exhaustive()
    }
}

impl std::fmt::Display for SealedObjectStore {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "SealedObjectStore({})", self.inner)
    }
}

impl SealedObjectStore {
    fn aad_for_path(&self, location: &ObjectPath) -> [u8; 32] {
        compute_aad(location.as_ref())
    }
}

#[async_trait]
impl ObjectStore for SealedObjectStore {
    async fn put_opts(
        &self,
        location: &ObjectPath,
        payload: PutPayload,
        opts: PutOptions,
    ) -> object_store::Result<PutResult> {
        eprintln!("  [trace] put_opts({}, len={})", location, payload.content_length());
        // Aggregate all Bytes chunks from PutPayload into a single
        // contiguous Vec<u8> for sealing. PutPayload is internally a
        // collection of Bytes; the spike materialises everything in
        // memory which is acceptable for the per-file granularity
        // locked at iteration 3 §3.1.
        let plaintext: Vec<u8> = payload
            .iter()
            .flat_map(|b| b.iter().copied())
            .collect();
        let aad = self.aad_for_path(location);
        let sealed = seal_file_bytes(&plaintext, &self.key, &aad);
        let sealed_payload: PutPayload = sealed.into();
        self.inner.put_opts(location, sealed_payload, opts).await
    }

    async fn put_multipart_opts(
        &self,
        _location: &ObjectPath,
        _opts: PutMultipartOpts,
    ) -> object_store::Result<Box<dyn MultipartUpload>> {
        // Per-file sealing requires the full plaintext at seal time;
        // streaming multipart writes don't fit that model without
        // complex buffering. For spike scope, fail loudly — Lance
        // will surface the limitation if it tries multipart writes
        // for our small dataset (likely it falls back to put_opts
        // for sub-100KB payloads).
        Err(object_store::Error::NotSupported {
            source: "SealedObjectStore: put_multipart not implemented in spike (per-file granularity locked at iteration 3 §3.1; multipart streaming would need block-level granularity)".into(),
        })
    }

    async fn get_opts(
        &self,
        location: &ObjectPath,
        options: GetOptions,
    ) -> object_store::Result<GetResult> {
        eprintln!(
            "  [trace] get_opts({}, range={:?}, head={})",
            location, options.range, options.head
        );
        // Always fetch the WHOLE sealed file — per-file granularity
        // requires whole-file decryption. If Lance requested a byte
        // range OR head-only, fetch full body anyway and slice/strip
        // from the unsealed plaintext below. Spike-cost: every head
        // becomes a full-file read; T0.2.0 Phase 1+ can store
        // unsealed_size in a sidecar / framing extension to optimise.
        let mut full_options = options;
        let requested_range = full_options.range.take();
        let was_head_only = full_options.head;
        full_options.head = false;

        let sealed_get = self.inner.get_opts(location, full_options).await?;
        let sealed_meta = sealed_get.meta.clone();
        let sealed_attributes = sealed_get.attributes.clone();
        let sealed_bytes = sealed_get.bytes().await?;

        let aad = self.aad_for_path(location);
        let plaintext = unseal_file_bytes(&sealed_bytes, &self.key, &aad).map_err(|e| {
            object_store::Error::Generic {
                store: "SealedObjectStore",
                source: e.into(),
            }
        })?;

        let plaintext_len = plaintext.len();
        let (range, body): (std::ops::Range<usize>, Vec<u8>) = match requested_range {
            None => (0..plaintext_len, plaintext),
            Some(object_store::GetRange::Bounded(r)) => {
                let start = (r.start as usize).min(plaintext_len);
                let end = (r.end as usize).min(plaintext_len);
                let slice = plaintext[start..end].to_vec();
                (start..end, slice)
            }
            Some(object_store::GetRange::Offset(o)) => {
                let start = (o as usize).min(plaintext_len);
                let slice = plaintext[start..].to_vec();
                (start..plaintext_len, slice)
            }
            Some(object_store::GetRange::Suffix(suffix)) => {
                let start = plaintext_len.saturating_sub(suffix as usize);
                let slice = plaintext[start..].to_vec();
                (start..plaintext_len, slice)
            }
        };

        // For head-only requests, return an empty payload but the
        // correctly-sized meta. Some object_store consumers won't
        // touch the body on a HEAD; spike returns empty rather than
        // re-streaming the unsealed body to avoid surprise consumers.
        let body_bytes = if was_head_only {
            BytesBuf::new()
        } else {
            BytesBuf::from(body)
        };
        let payload_stream: BoxStream<'static, object_store::Result<BytesBuf>> =
            stream::once(async move { Ok(body_bytes) }).boxed();

        let unsealed_meta = ObjectMeta {
            location: sealed_meta.location,
            last_modified: sealed_meta.last_modified,
            size: plaintext_len,
            e_tag: sealed_meta.e_tag,
            version: sealed_meta.version,
        };

        Ok(GetResult {
            payload: GetResultPayload::Stream(payload_stream),
            meta: unsealed_meta,
            range,
            attributes: sealed_attributes,
        })
    }

    async fn head(&self, location: &ObjectPath) -> object_store::Result<ObjectMeta> {
        // Subtract the constant per-file sealing overhead so Lance
        // sees the unsealed Parquet/Lance file size — matches
        // get_opts's unsealed_meta.size convention.
        let mut meta = self.inner.head(location).await?;
        let inner_size = meta.size;
        meta.size = meta.size.saturating_sub(SEAL_OVERHEAD);
        eprintln!(
            "  [trace] head({}) sealed={} unsealed={}",
            location, inner_size, meta.size
        );
        Ok(meta)
    }

    async fn delete(&self, location: &ObjectPath) -> object_store::Result<()> {
        self.inner.delete(location).await
    }

    fn list(
        &self,
        prefix: Option<&ObjectPath>,
    ) -> BoxStream<'_, object_store::Result<ObjectMeta>> {
        eprintln!("  [trace] list(prefix={:?})", prefix);
        // Translate sealed sizes back to unsealed sizes inline so
        // Lance-internal consumers that read meta.size from list
        // results see the same view as head() / get_opts().
        self.inner
            .list(prefix)
            .map(|res| {
                res.map(|mut meta| {
                    meta.size = meta.size.saturating_sub(SEAL_OVERHEAD);
                    meta
                })
            })
            .boxed()
    }

    async fn list_with_delimiter(
        &self,
        prefix: Option<&ObjectPath>,
    ) -> object_store::Result<ListResult> {
        let mut result = self.inner.list_with_delimiter(prefix).await?;
        for meta in &mut result.objects {
            meta.size = meta.size.saturating_sub(SEAL_OVERHEAD);
        }
        Ok(result)
    }

    async fn copy(&self, from: &ObjectPath, to: &ObjectPath) -> object_store::Result<()> {
        // AAD-binding caveat: a sealed file at `from` has AAD bound
        // to from's path; a raw byte-copy to `to` produces a sealed
        // blob whose AAD doesn't match its new location, and reads
        // from `to` will fail closed. Spike scope doesn't exercise
        // this path; T0.2.0 Phase 1+ will need unseal-reseal copy.
        self.inner.copy(from, to).await
    }

    async fn copy_if_not_exists(
        &self,
        from: &ObjectPath,
        to: &ObjectPath,
    ) -> object_store::Result<()> {
        self.inner.copy_if_not_exists(from, to).await
    }
}

