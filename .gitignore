# =====================================================================
# Memory Vault — .gitignore
# Goal: NEVER commit secrets, keys, encrypted vaults, ML model files,
# or build artifacts. Cargo.lock IS committed (BRD §2.9 / §4).
# =====================================================================

# ---------- Rust / Cargo ----------
target/
**/target/
**/*.rs.bk
*.pdb

# ---------- Tauri ----------
src-tauri/target/
src-tauri/gen/
# T0.1.11 Phase 3: vault-tauri lives under crates/ (not the default src-tauri/),
# so the auto-generated gen/ schemas + capability files land under
# crates/vault-tauri/gen/. Same exclusion intent as src-tauri/gen/ above.
crates/vault-tauri/gen/
ui/node_modules/
ui/dist/
ui/build/
ui/.next/
ui/.svelte-kit/

# ---------- Node / TS (cloud Workers, frontend) ----------
node_modules/
**/node_modules/
.pnp.*
yarn-debug.log*
yarn-error.log*
npm-debug.log*
pnpm-debug.log*
.npm/
.yarn/
.pnpm-store/

# ---------- Secrets / credentials (NEVER commit) ----------
.env
.env.*
!.env.example
!.env.sample
.envrc
secrets/
.secrets/
*.secret
*.secrets

# Auth tokens, OAuth credentials, service accounts
*credential*.json
*credentials*.json
client_secret*.json
service-account*.json
*-service-account.json
gcloud-key*.json
auth-config.json

# Cloud provider credentials
.aws/
.gcloud/
.azure/
.cloudflare/
wrangler.toml.local
.dev.vars

# Generic key/cert material
*.pem
*.key
*.priv
*.private
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore
*.asc
*.gpg
private-key*
*-private-key*

# API tokens, session tokens
*.token
*.tokens
api-key*
*api_key*

# ---------- Memory Vault — user data (NEVER commit) ----------
# Local dev databases
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal

# Test fixture — captured V0.1 binary's SQLCipher DB for ADR-041 §5 Tier 2
# bridge test. Safe-to-commit (capture key is `fixture-capture-key-do-not-
# use-in-prod`; never used in production).
!crates/vault-storage/tests/fixtures/v0_1_alpha_data_dir/vault.db
!crates/vault-storage/tests/fixtures/v0_1_alpha_data_dir/vault.db-wal

# Encrypted vault files
*.vault
.vault/
vault-data/
user-data/

# Audit logs (may contain sensitive metadata)
audit.log
audit-*.log
*.audit

# Sync state / local caches
.sync/
sync-state/
.cache/

# ---------- ML model files (large binaries; downloaded at first launch) ----------
models/
*.gguf
*.onnx
*.bin
*.safetensors
*.pt
*.pth
*.ggml
tokenizer.json
!crates/vault-embedding/tests/fixtures/tokenizer.json

# ---------- Logs / debug ----------
*.log
logs/
debug/
core
core.*

# ---------- IDE / editor ----------
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project
.zed/
.cursor/
.fleet/

# ---------- OS ----------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini
$RECYCLE.BIN/
ehthumbs.db
*.lnk

# ---------- Backup / temp files ----------
*.bak
*.backup
*_backup
*~backup
*.tmp
*.temp
*.orig
*.rej

# ---------- Coverage / profiling ----------
*.profraw
*.profdata
coverage/
lcov.info
tarpaulin-report.html

# ---------- Local notes (exclude private scratch files) ----------
NOTES.local.md
SCRATCH.md
TODO.local.md
.private/

# ---------- Claude Code per-machine state ----------
# Project-shared settings (.claude/settings.json) MAY be committed if we want
# to share permission baselines across machines. Per-machine local permissions
# and session state must NOT be committed. The directory-wide ignore catches
# session locks (e.g. `scheduled_tasks.lock`) so they stop surfacing as
# untracked; un-ignore specific files (e.g. `!.claude/settings.json`) when
# we want to share them.
.claude/
.claude/settings.local.json
.claude/.session/
.claude/cache/

# ---------- MCP tool scratch dirs (per-machine, never committed) ----------
# Playwright MCP writes browser session/trace scratch here during dogfooding.
.playwright-mcp/

# ---------- Project rules / agent instructions (local-only per Shahbaz) ----------
# CLAUDE.md is the project-scoped rules file Claude Code auto-loads each session.
# Shahbaz's preference (2026-04-28): never commit this file — keep it per-machine.
# See HANDOFF.md ADR-004.
CLAUDE.md
.claude/CLAUDE.md
